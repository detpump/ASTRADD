# Aster API Keys
ASTER_API_KEY=your_aster_api_key_here
ASTER_API_SECRET=your_aster_api_secret_here
ASTER_USER=0x...
ASTER_SIGNER=0x...
ASTER_PRIVATE_KEY=0x...

# MiniMax LLM
MINIMAX_API_KEY=your_minimax_api_key_here

# Anthropic (alternative LLM)
