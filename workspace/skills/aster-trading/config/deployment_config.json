{
    "environments": {
        "development": {
            "name": "Development",
            "trading_mode": "paper",
            "log_level": "DEBUG",
            "database_url": "postgresql://aster:dev@localhost:5432/aster_trading_dev",
            "redis_url": "redis://localhost:6379/0",
            "api_endpoint": "https://paper-api.aster.com",
            "features": {
                "circuit_breaker": true,
                "trade_deduplication": true,
                "risk_management": true,
                "telegram_notifications": false
            },
            "limits": {
                "max_position_size": 1000,
                "risk_per_trade": 0.01,
                "max_daily_trades": 10
            }
        },
        "staging": {
            "name": "Staging",
            "trading_mode": "paper",
            "log_level": "INFO",
            "database_url": "postgresql://aster:staging@aster-db:5432/aster_trading_staging",
            "redis_url": "redis://aster-redis:6379/0",
            "api_endpoint": "https://paper-api.aster.com",
            "features": {
                "circuit_breaker": true,
                "trade_deduplication": true,
                "risk_management": true,
                "telegram_notifications": true
            },
            "limits": {
                "max_position_size": 5000,
                "risk_per_trade": 0.02,
                "max_daily_trades": 50
            }
        },
        "production": {
            "name": "Production",
            "trading_mode": "live",
            "log_level": "WARNING",
            "database_url": "postgresql://aster:prod@aster-db-prod:5432/aster_trading_prod",
            "redis_url": "redis://aster-redis-prod:6379/0",
            "api_endpoint": "https://api.aster.com",
            "features": {
                "circuit_breaker": true,
                "trade_deduplication": true,
                "risk_management": true,
                "telegram_notifications": true
            },
            "limits": {
                "max_position_size": 10000,
                "risk_per_trade": 0.02,
                "max_daily_trades": 100
            }
        }
    },
    "deployment": {
        "pre_deployment_checks": [
            "Run full test suite: python3 -m pytest tests/ -v",
            "Verify configuration: python3 -c 'from src.config_loader import load_config; load_config()'",
            "Check database connectivity",
            "Verify Redis connectivity",
            "Check API credentials"
        ],
        "deployment_steps": [
            {
                "step": 1,
                "name": "Backup current state",
                "command": "cp -r state/ state/backup_$(date +%Y%m%d_%H%M%S)"
            },
            {
                "step": 2,
                "name": "Install dependencies",
                "command": "pip install -r requirements.txt"
            },
            {
                "step": 3,
                "name": "Run database migrations",
                "command": "alembic upgrade head"
            },
            {
                "step": 4,
                "name": "Verify configuration",
                "command": "python3 -c 'from src.config_loader import load_config; load_config()'"
            },
            {
                "step": 5,
                "name": "Start application",
                "command": "./control.sh restart"
            },
            {
                "step": 6,
                "name": "Run smoke tests",
                "command": "python3 -m pytest tests/test_integration.py -v"
            }
        ],
        "rollback_procedures": {
            "emergency_stop": {
                "description": "Immediate stop of all trading activities",
                "steps": [
                    {
                        "step": 1,
                        "action": "Stop trading system",
                        "command": "./control.sh stop"
                    },
                    {
                        "step": 2,
                        "action": "Close all open positions via exchange UI or API",
                        "command": "Manual action required"
                    },
                    {
                        "step": 3,
                        "action": "Notify team via Telegram",
                        "command": "Manual action required"
                    }
                ]
            },
            "configuration_rollback": {
                "description": "Rollback to previous configuration",
                "steps": [
                    {
                        "step": 1,
                        "action": "Stop system",
                        "command": "./control.sh stop"
                    },
                    {
                        "step": 2,
                        "action": "Restore configuration from backup",
                        "command": "cp config/risk_config.json.bak config/risk_config.json"
                    },
                    {
                        "step": 3,
                        "action": "Restart system",
                        "command": "./control.sh start"
                    }
                ]
            },
            "code_rollback": {
                "description": "Rollback to previous version",
                "steps": [
                    {
                        "step": 1,
                        "action": "Stop system",
                        "command": "./control.sh stop"
                    },
                    {
                        "step": 2,
                        "action": "Checkout previous version",
                        "command": "git checkout <commit-hash>"
                    },
                    {
                        "step": 3,
                        "action": "Restore dependencies",
                        "command": "pip install -r requirements.txt"
                    },
                    {
                        "step": 4,
                        "action": "Restore configuration if needed",
                        "command": "cp -r state/backup_* state/"
                    },
                    {
                        "step": 5,
                        "action": "Restart system",
                        "command": "./control.sh start"
                    },
                    {
                        "step": 6,
                        "action": "Verify system health",
                        "command": "python3 -m pytest tests/test_integration.py -v"
                    }
                ]
            },
            "database_rollback": {
                "description": "Rollback database migrations",
                "steps": [
                    {
                        "step": 1,
                        "action": "Stop system",
                        "command": "./control.sh stop"
                    },
                    {
                        "step": 2,
                        "action": "Backup current database",
                        "command": "pg_dump aster_trading > backup_$(date +%Y%m%d).sql"
                    },
                    {
                        "step": 3,
                        "action": "Downgrade migrations",
                        "command": "alembic downgrade -1"
                    },
                    {
                        "step": 4,
                        "action": "Restart system",
                        "command": "./control.sh start"
                    }
                ]
            }
        },
        "health_monitoring": {
            "startup_health_check": {
                "enabled": true,
                "timeout_seconds": 60,
                "checks": [
                    {
                        "name": "database",
                        "critical": true,
                        "command": "python3 -c 'from src.common_imports import get_db; get_db()'"
                    },
                    {
                        "name": "redis",
                        "critical": true,
                        "command": "python3 -c 'import redis; r = redis.from_url(\"redis://localhost:6379\"); r.ping()'"
                    },
                    {
                        "name": "api_connectivity",
                        "critical": true,
                        "command": "python3 -c 'from src.api.aster_api import is_api_healthy; print(is_api_healthy())'"
                    }
                ]
            },
            "post_deployment_monitoring": {
                "duration_minutes": 30,
                "checks": [
                    {
                        "name": "error_rate",
                        "threshold": 0.05,
                        "alert_if_exceeded": true
                    },
                    {
                        "name": "validation_failures",
                        "threshold": 10,
                        "alert_if_exceeded": true
                    },
                    {
                        "name": "circuit_breaker_state",
                        "expected": "CLOSED",
                        "alert_if_different": true
                    }
                ]
            }
        }
    }
}
