{
  "version": "1.0.0",
  "description": "Centralized configuration for all magic numbers and system parameters",
  
  "api": {
    "base_url": "https://fapi.asterdex.com",
    "timeout_seconds": 10,
    "rate_limit_min_interval_ms": 100,
    
    "circuit_breaker": {
      "failure_threshold": 5,
      "success_threshold": 2,
      "timeout_seconds": 30.0,
      "half_open_max_calls": 3
    },
    
    "retry": {
      "max_retries": 3,
      "base_delay_seconds": 0.5,
      "max_delay_seconds": 10.0,
      "exponential_base": 2.0
    }
  },
  
  "trading": {
    "default_leverage": 5,
    "min_notional_usdt": 5.0,
    "default_sl_pct": 1.5,
    "default_tp1_pct": 1.5,
    "default_tp2_pct": 3.0,
    "tp1_quantity_pct": 0.5,
    "tp2_quantity_pct": 0.5
  },
  
  "risk": {
    "max_position_pct": 0.05,
    "max_total_exposure_pct": 0.20,
    "max_daily_loss_pct": 0.05,
    "max_drawdown_pct": 0.20,
    "max_trades_per_day": 20,
    "default_position_multiplier": 1.0,
    
    "cooldown": {
      "after_stop_loss_seconds": 900,
      "after_tp2_seconds": 60,
      "min_trade_interval_seconds": 900
    }
  },
  
  "system": {
    "main_loop_seconds": 60,
    "feature_update_seconds": 60,
    "llm_review_hours": 3,
    "state_save_interval_ms": 60000,
    "equity_fetch_cache_ms": 60000,
    
    "debounce": {
      "signal_window_seconds": 10.0,
      "scale_in_check_interval_loops": 5,
      "risk_adjustment_interval_loops": 180
    }
  },
  
  "logging": {
    "deduplication_window_seconds": 5.0,
    "cache_ttl_seconds": 5.0
  },
  
  "scale_in": {
    "enabled": true,
    "min_pnl_pct_for_scale_in": 1.0,
    "scale_in_quantity_pct": 0.3,
    "max_scale_ins_per_position": 2,
    "scale_in_cooldown_seconds": 300
  },
  
  "symbols": {
    "default_list": ["ASTERUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "HYPEUSDT"],
    "intervals": ["1m", "5m", "15m"]
  },
  
  "ml": {
    "min_signal_strength": 0.10,
    "feature_klines_limit": 100,
    "order_book_depth": 20,
    "recent_trades_limit": 100
  },
  
  "llm": {
    "provider": "anthropic",
    "model": "claude-3-haiku-20240307",
    "max_calls_per_hour": 1,
    "max_calls_per_day": 20,
    "cooldown_seconds": 3600
  }
}
