@dataclass
class TradingConfig:
    """Main system configuration"""
    # Symbols to trade
    symbols: List[str] = field(default_factory=lambda: ["ASTERUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "HYPEUSDT"])
    
    # Analysis intervals
    intervals: List[str] = field(default_factory=lambda: ["1m", "5m", "15m"])
    
    # Main loop cycle
    main_loop_seconds: int = 60          # How often to run main loop
    feature_update_seconds: int = 60     # How often to update features
    llm_review_hours: int = 3            # How often to review with LLM
    
    # APIs
    use_testnet: bool = False
    
    # Paths - Use centralized paths module (single point of change for server migration)
    # Import from paths.py - single source of truth
    models_path: str = ""
    logs_path: str = ""
    state_path: str = ""
    config_path: str = ""
    
    def __post_init__(self):
        """Initialize paths from centralized module"""
        if not self.models_path:
            try:
                from paths import MODELS_DIR, LOGS_DIR, STATE_DIR, CONFIG_DIR
                self.models_path = MODELS_DIR
                self.logs_path = LOGS_DIR
                self.state_path = STATE_DIR
                self.config_path = CONFIG_DIR
            except ImportError:
                # Fallback - should not happen if paths.py exists
                base = "/Users/FIRMAS/.openclaw/workspace/skills/aster-trading"
                self.models_path = f"{base}/models"
                self.logs_path = f"{base}/logs"
                self.state_path = f"{base}/data/state"
                self.config_path = f"{base}/config"


@dataclass
class SystemState:
    """Estado del sistema"""
    running: bool = False
    start_time: int = 0
    loop_count: int = 0
    last_feature_update: int = 0
    last_llm_review: int = 0
    trades_executed: int = 0
    errors: List[str] = field(default_factory=list)


class TradingSystemV2:
    """
    Sistema de Trading V2
    
    Integra:
    - WebSocket para datos real-time
    - Feature Engineering (200+ features)
    - ML Signal Generator (XGBoost)
    - LLM Guardian (limitado - 1x/hora)
    - Risk Guard (controles dinámicos)
    """
    
    def __init__(self, config: TradingConfig = None):
        self.config = config or TradingConfig()
        
        # Estado
        self.state = SystemState()
        # FIX #3: Set start_time immediately in __init__ so state is never empty
        # This ensures v2_state.json always has a valid start_time
        self.state.start_time = int(time.time() * 1000)
        self.state.running = False  # Will be set to True in start()
        
        # Componentes
        self.ws_manager: Optional[AsterWebSocketManager] = None
        self.feature_calculator: Optional[FeatureCalculator] = None
        self.signal_generator: Optional[SignalGenerator] = None
        self.llm_guardian: Optional[LLMGuardian] = None
        self.risk_guard: Optional[RiskGuard] = None
        self.risk_adjuster: Optional[DynamicRiskAdjuster] = None
        
        # Estado interno
        self.current_features: Dict[str, Any] = {}
        self.last_signals: Dict[str, TradingSignal] = {}
        
        # Debouncing para evitar excesivo procesamiento (max 1 signal por symbol per 10 seconds)
        self._signal_debounce: Dict[str, float] = {}
        self._debounce_window_seconds: float = 10.0
        
        # Bandera para evitar ejecución concurrente de señales (with asyncio.Lock for thread safety)
        self._processing_signal: Dict[str, bool] = {}
        self._signal_lock = asyncio.Lock()  # FIX: Add lock for thread-safe signal processing
        
        # Centralized logger for OpenClaw integration
        self.centralized_logger: Optional[CentralizedLogger] = None
        
        # Trade Execution Tracker - tracks signal-to-order lifecycle with correlation IDs
        self.trade_tracker = TradeExecutionTracker()
        
        # Healing metrics - tracks self-healing actions
        self._healing_metrics = {
            'total_heals': 0,
            'sl_orders_added': 0,
            'tp_orders_added': 0,
            'leverage_adjusted': 0,
            'stale_positions_cleaned': 0,
            'last_heal_timestamp': None,
            'heal_errors': []
        }
        
        # Crear directorios
        os.makedirs(self.config.models_path, exist_ok=True)
        os.makedirs(self.config.logs_path, exist_ok=True)
        os.makedirs(self.config.state_path, exist_ok=True)
        
        logger.info("=" * 50)
        logger.info("Trading System V2 inicializado")
        logger.info("=" * 50)
    
    async def initialize(self):
        """Inicializa todos los componentes - WITH HEAVY LOGGING TO DEBUG HANG"""
        init_start = time.time()
        logger.info("=" * 60)
        logger.info("INITIALIZATION STARTING - WITH DETAILED TIMING LOGS")
        logger.info("=" * 60)
        
        # 1. WebSocket Manager
        step_start = time.time()
        logger.info("[INIT] Step 1/10: WebSocket Manager... (t=0s)")
        self.ws_manager = AsterWebSocketManager(testnet=self.config.use_testnet)
        logger.info(f"[INIT] ✅ Step 1 complete: WebSocket Manager ({time.time() - step_start:.2f}s)")
        
        # 2. Feature Calculator
        step_start = time.time()
        logger.info("[INIT] Step 2/10: Feature Calculator...")
        fc_config = FeatureConfig(
            symbols=self.config.symbols,
            kline_intervals=self.config.intervals
        )
        self.feature_calculator = FeatureCalculator(fc_config)
        logger.info(f"[INIT] ✅ Step 2 complete: Feature Calculator ({time.time() - step_start:.2f}s)")
        
        # 2b. CRITICAL: Sync equity FIRST before any other operations
        step_start = time.time()
        logger.info("[INIT] Step 3/10: Early equity sync (BEFORE KLINES)...")
        try:
            from api.aster_api import reset_circuit_breaker, get_api_health_status
            # Reset circuit breaker to ensure API calls work
            reset_circuit_breaker()
            logger.info(f"[INIT]    Circuit breaker status: {get_api_health_status()}")
            
            api_equity = self._get_api_equity()
            if api_equity and api_equity > 0:
                logger.info(f"[INIT]    ✅ Equity synced early: ${api_equity:.2f}")
            else:
                logger.warning(f"[INIT]    ⚠️ Equity is {api_equity} from API")
        except Exception as e:
            logger.warning(f"[INIT]    ⚠️ Early equity sync failed: {e}")
        logger.info(f"[INIT] ✅ Step 3 complete: Early equity sync ({time.time() - step_start:.2f}s)")
        
        # 3. Risk Guard (needs equity before klines)
        step_start = time.time()
        logger.info("[INIT] Step 4/10: Risk Guard initialization...")
        risk_config = RiskConfig(
            max_position_pct=0.05,
            max_total_exposure_pct=0.20,
            max_daily_loss_pct=0.05,
            max_drawdown_pct=0.20,
            max_trades_per_day=20,
            use_dynamic_sizing=True,
            reduce_on_drawdown=True
        )
        self.risk_guard = get_shared_risk_guard()
        
        # Sync equity to risk guard now
        try:
            api_equity = self._get_api_equity()
            self.risk_guard.update_equity(api_equity)
            logger.info(f"[INIT]    ✅ Equity synced to RiskGuard: ${api_equity:.2f}")
        except Exception as e:
            logger.warning(f"[INIT]    ⚠️ Equity sync to RiskGuard failed: {e}")
        logger.info(f"[INIT] ✅ Step 4 complete: Risk Guard ({time.time() - step_start:.2f}s)")
        
        # CRITICAL: Save state NOW even before klines fetch
        # This ensures equity is saved even if klines timeout forever
        step_start = time.time()
        logger.info("[INIT] Step 5/10: Save state BEFORE klines (CRITICAL)...")
        
        # FIX #3b: Sync positions BEFORE saving state so positions show in v2_state.json
        try:
            api_positions = self._get_api_positions()
            if api_positions:
                self.risk_guard.sync_with_exchange(api_positions)
                logger.info(f"[INIT]    ✅ Positions synced before state save: {len(api_positions)} open positions")
        except Exception as e:
            logger.warning(f"[INIT]    ⚠️ Position sync failed: {e}")
        
        self._save_state()
        logger.info(f"[INIT] ✅ Step 5 complete: State saved ({time.time() - step_start:.2f}s)")
        logger.info(f"[INIT] ⏱️ Total elapsed so far: {time.time() - init_start:.2f}s")
        
        # 4. Signal Generator (will be after klines) - WITH MORE DETAILED TIMING
        step_start = time.time()
        logger.info("[INIT] Step 6/10: Fetching klines in PARALLEL (3s timeout each)...")
        
        async def fetch_klines_parallel():
            """Fetch klines in PARALLEL with reduced timeout to speed up initialization"""
            kline_fetch_start = time.time()
            try:
                from api.aster_api import get_klines
                import asyncio
                
                # Create all fetch tasks in parallel
                async def fetch_single_kline(symbol: str, interval: str):
                    """Fetch a single symbol/interval combination with timeout"""
                    fetch_start = time.time()
                    try:
                        klines = await asyncio.wait_for(
                            asyncio.to_thread(get_klines, symbol, interval, 100),
                            timeout=3.0  # Reduced from 10s to 3s for faster init
                        )
                        elapsed = time.time() - fetch_start
                        logger.info(f"     ✓ {symbol} {interval}: {len(klines)} klines in {elapsed:.2f}s")
                        return symbol, interval, klines
                    except asyncio.TimeoutError:
                        elapsed = time.time() - fetch_start
                        logger.warning(f"     ⚠️ {symbol} {interval}: timeout after {elapsed:.2f}s, using empty")
                        return symbol, interval, []
                    except Exception as e:
                        elapsed = time.time() - fetch_start
                        logger.warning(f"     ⚠️ {symbol} {interval}: error after {elapsed:.2f}s: {e}")
                        return symbol, interval, []
                
                # Create all tasks
                tasks = []
                for symbol in self.config.symbols:
                    for interval in self.config.intervals:
                        tasks.append(fetch_single_kline(symbol, interval))
                
                total_tasks = len(tasks)
                logger.info(f"     >>> Starting {total_tasks} parallel kline fetches at t={time.time() - init_start:.1f}s...")
                
                # Execute all in parallel
                results = await asyncio.gather(*tasks, return_exceptions=True)
                
                total_klines = 0
                # Process results
                for result in results:
                    if isinstance(result, Exception):
                        continue
                    symbol, interval, klines = result
                    total_klines += len(klines) if klines else 0
                    
                    # Initialize price history
                    self.feature_calculator.price_history.setdefault(symbol, {})[interval] = deque(maxlen=500)
                    
                    if klines and len(klines) > 0:
                        for k in klines:
                            self.feature_calculator.update_kline(symbol, interval, k)
                
                total_time = time.time() - kline_fetch_start
                logger.info(f"     >>> Step 6a complete: Fetched {total_klines} total klines in {total_time:.2f}s")
                        
            except Exception as e:
                logger.warning(f"  ⚠️ Error fetching klines: {e}")
                # Initialize empty price history as fallback
                for symbol in self.config.symbols:
                    for interval in self.config.intervals:
                        self.feature_calculator.price_history.setdefault(symbol, {})[interval] = deque(maxlen=500)
        
        step_start = time.time()
        logger.info(f"[INIT] >>> Step 6 START: Fetching klines at t={time.time() - init_start:.1f}s...")
        await fetch_klines_parallel()
        step6_time = time.time() - step_start
        logger.info(f"[INIT] ✅ Step 6 complete: Parallel klines fetch ({step6_time:.2f}s)")
        logger.info(f"[INIT] ⏱️ Total elapsed after Step 6: {time.time() - init_start:.2f}s")
        
        # 7. Signal Generator
        step_start = time.time()
        logger.info("[INIT] Step 7/10: Signal Generator (ML)...")
        logger.info(f"[INIT] ✅ Step 7 complete: Signal Generator ({time.time() - step_start:.2f}s)")
        ml_config = ModelConfig()
        self.signal_generator = SignalGenerator(ml_config, self.config.models_path)
        
        # 8. LLM Guardian - use Anthropic Haiku
        step_start = time.time()
        logger.info("[INIT] Step 8/10: LLM Guardian (Anthropic Haiku)...")
        
        # Get API keys from environment
        anthropic_key = os.environ.get("ANTHROPIC_API_KEY", "")
        
        llm_settings = LLMSettings(
            provider="anthropic" if anthropic_key else "none",
            anthropic_api_key=anthropic_key,
            anthropic_model="claude-3-haiku-20240307",
            max_calls_per_hour=1,
            max_calls_per_day=20,
            cooldown_seconds=3600,
            call_on_doubtful=True,  # Only call LLM on uncertain signals
            call_on_regime_change=True,
            call_on_anomaly=True,
            call_on_schedule=True,
            schedule_interval_hours=self.config.llm_review_hours
        )
        self.llm_guardian = LLMGuardian(llm_settings)
        logger.info(f"[INIT] ✅ Step 8 complete: LLM Guardian ({time.time() - step_start:.2f}s)")
        
        # 9. Risk Guard
        step_start = time.time()
        logger.info("[INIT] Step 9a/10: Risk Guard...")
        risk_config = RiskConfig(
            max_position_pct=0.05,
            max_total_exposure_pct=0.20,
            max_daily_loss_pct=0.05,
            max_drawdown_pct=0.20,
            max_trades_per_day=20,
            use_dynamic_sizing=True,
            reduce_on_drawdown=True
        )
        self.risk_guard = get_shared_risk_guard()
        logger.info(f"[INIT] ✅ Step 9a complete: Risk Guard ({time.time() - step_start:.2f}s)")
        
        # 9b. Dynamic Risk Adjuster (LLM-driven)
        step_start = time.time()
        logger.info("[INIT] Step 9b/10: Dynamic Risk Adjuster (LLM)...")
        adjuster_config = AdjustmentConfig(
            cooldown_hours=3.0,
            max_calls_per_day=8
        )
        self.risk_adjuster = DynamicRiskAdjuster(adjuster_config)
        logger.info(f"[INIT] ✅ Step 9b complete: Dynamic Risk Adjuster ({time.time() - step_start:.2f}s)")
        
        # 10. Centralized Logger for OpenClaw integration
        step_start = time.time()
        logger.info("[INIT] Step 10/10: Centralized Logger (OpenClaw)...")
        self.centralized_logger = CentralizedLogger()
        logger.info(f"[INIT] ✅ Step 10 complete: Centralized Logger ({time.time() - step_start:.2f}s)")
        
        # CRITICAL: Reset circuit breaker on startup to allow fresh trading
        # This ensures previous trade history doesn't block new trades
        if self.risk_guard and hasattr(self.risk_guard, 'state'):
            old_last_trade = self.risk_guard.state.last_trade_time
            if old_last_trade > 0:
                logger.info(f"🔄 Resetting circuit breaker: last_trade_time was {old_last_trade}, setting to 0")
                self.risk_guard.state.last_trade_time = 0
                self.risk_guard._save_state()
                logger.info("✅ Circuit breaker reset - trading enabled")
        # FIX: Added try/except to prevent crash if API is unavailable during initialization
        try:
            api_equity = self._get_api_equity()
            self.risk_guard.update_equity(api_equity)
            logger.info(f"  - Equity synced: ${api_equity:.2f}")
        except Exception as e:
            logger.warning(f"  - Equity sync failed during init (will retry in main loop): {e}")
        
        # SYNC: Update RiskGuard with real exchange positions (with error handling)
        # FIX: Added try/except to prevent crash if API is unavailable during initialization
        try:
            api_positions = self._get_api_positions()
            self.risk_guard.sync_with_exchange(api_positions)
            logger.info(f"  - Positions synced: {len(api_positions)} open positions")
        except Exception as e:
            logger.warning(f"  - Positions sync failed during init (will retry in main loop): {e}")
        
        # CRITICAL FIX: Also sync trade_state to clear stale entries
        try:
            from trade_state import sync_all_with_exchange
            sync_result = sync_all_with_exchange()
            logger.info(f"  - trade_state synced: removed={sync_result.get('removed', [])}, synced={sync_result.get('synced', [])}")
        except Exception as e:
            logger.warning(f"  - trade_state sync failed during init: {e}")
        
        logger.info("✅ Componentes inicializados")
        
        # CRITICAL: Save initial state IMMEDIATELY after initialization
        # This ensures state shows system is ready even before main loop starts
        # Also try to sync equity one more time to ensure we have real data
        try:
            api_equity = self._get_api_equity()
            if api_equity and api_equity > 0:
                self.risk_guard.update_equity(api_equity)
                logger.info(f"✅ Equity synced before start: ${api_equity:.2f}")
            else:
                logger.warning(f"⚠️ Equity is {api_equity} - system may not be able to trade!")
        except Exception as e:
            logger.warning(f"⚠️ Final equity sync failed: {e}")
        
        # Mark system as running after successful initialization
        # This ensures the system shows as ACTIVE/RUNNING in status displays
        self.state.running = True
        logger.info("✅ System marked as RUNNING")
        
        # Save initial state with running=True
        self._save_state()
        logger.info("✅ Initial state saved")
    
    async def start(self):
        """Inicia el sistema de trading"""
        # DEBUG: Log state when start() is called
        logger.warning(f"🎯 [START] start() called - running={self.state.running}, loop_count={self.state.loop_count}")
        
        if self.state.running:
            # BUG FIX: Even if already running, we need to call _main_loop()!
            # The initialize() method sets running=True, so this check was preventing _main_loop() from running
            logger.warning(f"⚠️ [START] System shows running=True, but still calling _main_loop() to start trading loop!")
            # Don't return early - continue to start the main loop
            # return  # COMMENTED OUT TO FIX THE BUG
        
        logger.info("🚀 Iniciando Trading System V2...")
        self.state.running = True
        self.state.start_time = int(time.time() * 1000)
        
        try:
            # Conectar WebSocket
            if self.ws_manager:
                await self.ws_manager.connect()
                
                # Suscribirse a streams (only kline_1m and trade - no depth for efficiency)
                streams = []
                for symbol in self.config.symbols:
                    streams.append(StreamConfig(symbol=symbol, stream_type=StreamType.TRADE))
                    streams.append(StreamConfig(symbol=symbol, stream_type=StreamType.KLINE, interval="1m"))
                
                await self.ws_manager.subscribe(streams, self._on_data)
                
                # INICIAR LISTENING en background - ¡esto faltaba!
                asyncio.create_task(self.ws_manager.listen())
            
            # Loop principal
            await self._main_loop()
            
        except Exception as e:
            logger.error(f"Error en el loop principal: {e}")
            self.state.errors.append(str(e))
            
        finally:
            await self.stop()
    
    async def stop(self):
        """Detiene el sistema"""
        logger.info("🛑 Deteniendo sistema...")
        self.state.running = False
        
        if self.ws_manager:
            await self.ws_manager.disconnect()
        
        logger.info("✅ Sistema detenido")
    
    async def _on_data(self, data: Dict):
        """Callback para datos entrantes del WebSocket - EVENT-DRIVEN SIGNAL GENERATION"""
        try:
            current_time = time.time()
            
            # Update features with new data
            if self.feature_calculator and self.ws_manager:
                for symbol in self.config.symbols:
                    # Get latest klines
                    klines = self.ws_manager.klines.get(symbol, [])
                    
                    for kline in klines[-1:]:  # Only the last
                        self.feature_calculator.update_kline(symbol, "1m", {
                            "open": kline.open,
                            "high": kline.high,
                            "low": kline.low,
                            "close": kline.close,
                            "volume": kline.volume,
                            "close_time": kline.close_time
                        })
                    
                    self.state.last_feature_update = int(current_time * 1000)
                    
                    # IMMEDIATE SIGNAL GENERATION - Event-driven
                    # FIX: Move debounce check inside lock to prevent race condition
                    # Check debounce to prevent excessive computation
                    async with self._signal_lock:
                        last_signal_time = self._signal_debounce.get(symbol, 0)
                        if (current_time - last_signal_time) >= self._debounce_window_seconds:
                            # Check if already processing a signal for this symbol
                            # Double-check inside lock to prevent race condition
                            if not self._processing_signal.get(symbol, False):
                                self._processing_signal[symbol] = True  # Mark as processing BEFORE awaiting
                                try:
                                    # Trigger immediate signal generation
                                    await self._generate_signal_immediate(symbol)
                                except Exception as e:
                                    logger.error(f"Error in signal generation: {e}")
                                finally:
                                    # Ensure flag is cleared even on error
                                    self._processing_signal[symbol] = False
            
            # Save state every 60 seconds only (not on every message)
            current_time_ms = int(time.time() * 1000)
            if not hasattr(self, '_last_state_save') or (current_time_ms - self._last_state_save) > 60000:
                self._save_state()
                self._last_state_save = current_time_ms
                    
        except Exception as e:
            import traceback
            logger.error(f"Error procesando datos: {e}")
            logger.error(f"Traceback: {traceback.format_exc()}")
    
    async def _generate_signal_immediate(self, symbol: str):
        """Generate signal immediately when new kline arrives - Event-driven"""
        # Note: _processing_signal[symbol] is now set by caller inside lock
        try:
            self._signal_debounce[symbol] = time.time()
            
            logger.debug(f"⚡ Event-driven signal generation for {symbol}")
            
            # Get order book
            order_book = None
            if self.ws_manager:
                ob = self.ws_manager.get_order_book(symbol)
                if ob:
                    order_book = {
                        "bids": [[p, q] for p, q in ob.bids],
                        "asks": [[p, q] for p, q in ob.asks]
                    }
            
            # Get recent trades
            trades = []
            if self.ws_manager:
                recent = self.ws_manager.get_recent_trades(symbol, 100)
                trades = [{"quantity": t.quantity, "is_buyer_maker": t.is_buyer_maker} for t in recent]
            
            # Calculate features IMMEDIATELY after kline update
            try:
                features = self.feature_calculator.calculate_all_features(
                    symbol,
                    order_book=order_book,
                    trades=trades
                )
            except Exception as fe:
                logger.error(f"Error calculating features for {symbol}: {fe}")
                # Flag cleared by caller
                return
            
            # Get current price
            price = 0.0
            if order_book and order_book.get("bids"):
                price = float(order_book["bids"][0][0])
            else:
                klines = self.feature_calculator.price_history.get(symbol, {}).get("1m", [])
                if klines:
                    price = klines[-1]["close"]
            
            if not features:
                logger.warning(f"Features empty for {symbol}, skipping signal generation")
                # Flag cleared by caller
                return
            
            # Convert features to dict
            try:
                features_dict = features.to_dict()
                features_dict["price"] = price
            except Exception as fe2:
                logger.error(f"Error converting features to dict for {symbol}: {fe2}")
                self._processing_signal[symbol] = False
                return
            
            # Save features
            self.current_features[symbol] = features_dict
            
            # Generate signal IMMEDIATELY
            try:
                signal = self.signal_generator.predict(features_dict)
            except Exception as se:
                logger.error(f"Error generating signal for {symbol}: {se}")
                self._processing_signal[symbol] = False
                return
            
            self.last_signals[symbol] = signal
            
            # Log signal
            logger.info(f"⚡ {symbol}: {signal.action.name} (strength={signal.signal_strength:.2f}, conf={signal.confidence:.2f}) [EVENT-DRIVEN]")
            
            # If strong signal, evaluate and execute trade immediately
            if signal.action.name != "HOLD" and signal.signal_strength > 0.10:
                logger.info(f"🔥 Strong signal detected for {symbol}, evaluating trade immediately...")
                await self._evaluate_trade(symbol, signal, features_dict)
            
        except Exception as e:
            import traceback
            logger.error(f"Error in _generate_signal_immediate for {symbol}: {e}")
            logger.error(f"Traceback: {traceback.format_exc()}")
        # Note: _processing_signal[symbol] is cleared by caller
    
    def _get_market_prices(self) -> Dict[str, float]:
        """Obtiene precios actuales del mercado"""
        prices = {}
        try:
            if self.ws_manager:
                for symbol in self.config.symbols:
                    # Try order book first
                    ob = self.ws_manager.get_order_book(symbol)
                    if ob and ob.bids:
                        prices[symbol] = float(ob.bids[0][0])
                    else:
                        # Fallback to klines
                        klines = self.feature_calculator.price_history.get(symbol, {}).get("1m", [])
                        if klines:
                            prices[symbol] = float(klines[-1]["close"])
        except Exception as e:
            logger.error(f"Error getting market prices: {e}")
        return prices
    
    def _get_api_equity(self) -> float:
        """Obtiene equity real desde la API de Aster con fallback a último valor guardado
        
        Returns real equity from API. If API fails, tries cached values.
        If all fail, returns 0 but does NOT halt - allows system to keep trying on next loop.
        """
        error_context = "unknown error"
        try:
            from api.aster_api import get_equity_total_usdt
            equity = get_equity_total_usdt()
            logger.info(f"Equity from API: ${equity:.2f}")
            if equity and equity > 0:
                return equity
            # If equity is 0, don't treat as warning - could be a fresh account
            # Continue to fallback
        except Exception as e:
            error_context = str(e)
            logger.warning(f"Could not get equity from API: {e}")
        
        # Fallback: usar último valor guardado en risk_state.json (only if > 0)
        fallback_equity = self._get_cached_equity()
        if fallback_equity and fallback_equity > 0:
            logger.info(f"Using cached equity: ${fallback_equity:.2f}")
            return fallback_equity
        
        # If we get here, both API and cache failed to provide valid equity
        # Do NOT raise error - instead log warning and return 0
        # The system will keep retrying on each loop until equity is fetched successfully
        logger.warning(
            f"⚠️ Cannot get account equity from API or cache - "
            f"API error: {error_context}, cached: {fallback_equity}. "
            f"Will retry on next cycle. Trading may be limited until equity is fetched."
        )
        return 0.0  # Return 0 instead of raising - system will keep retrying
    
    def _get_cached_equity(self) -> float:
        """Obtiene el último equity guardado desde risk_state.json o v2_state.json"""
        # Primero intentar risk_state.json
        try:
            risk_file = os.path.join(self.config.logs_path, "risk_state.json")
            if os.path.exists(risk_file):
                with open(risk_file, "r") as f:
                    data = json.load(f)
                    equity = data.get("equity", 0.0)
                    if equity and equity > 0:
                        # Handle numpy types
                        if hasattr(equity, 'item'):
                            equity = float(equity.item())
                        return float(equity)
        except Exception as e:
            logger.warning(f"Could not read cached equity from risk_state: {e}")
        
        # Fallback a v2_state.json
        try:
            state_file = os.path.join(self.config.logs_path, "v2_state.json")
            if os.path.exists(state_file):
                with open(state_file, "r") as f:
                    data = json.load(f)
                    equity = data.get("equity", 0.0)
                    if equity and equity > 0:
                        if hasattr(equity, 'item'):
                            equity = float(equity.item())
                        return float(equity)
        except Exception as e:
            logger.warning(f"Could not read cached equity from v2_state: {e}")
        
        return 0.0
    
    def _get_api_positions(self) -> Dict[str, Dict]:
        """Obtiene posiciones ABIERTAS desde la API de Aster"""
        try:
            from api.aster_api import get_positions_v3
            positions = get_positions_v3()
            if positions:
                # Filter to only OPEN positions (positionAmt != 0)
                # This prevents false positives where closed positions are detected as open
                open_positions = {
                    p["symbol"]: p for p in positions 
                    if float(p.get("positionAmt", 0)) != 0
                }
                if open_positions:
                    logger.debug(f"Found {len(open_positions)} open positions: {list(open_positions.keys())}")
                return open_positions
        except Exception as e:
            logger.warning(f"Could not get positions from API: {e}")
        return {}
    
    def _save_state(self):
        """Guarda el estado del sistema en un archivo JSON
        
        This function coordinates state saving by calling sub-functions for each step.
        """
        try:
            # Step 1: Get equity (with caching)
            api_equity = self._get_equity_for_state()
            
            # Step 2: Load risk data from file
            risk_data = self._load_risk_data_for_state()
            
            # Step 3: Build signals data
            signals_data = self._build_signals_data()
            
            # Step 4: Get market prices
            market_prices = self._get_market_prices()
            
            # Step 5: Build and sanitize state data
            state_data = self._build_state_data(api_equity, risk_data, signals_data, market_prices)
            
            # Step 6: Write to file
            self._write_state_to_file(state_data)
                
        except Exception as e:
            logger.error(f"Error guardando estado: {e}")
    
    def _get_equity_for_state(self) -> float:
        """Get equity from API with caching - Step 1 of state saving
        
        FIX: Always fetch fresh from API if cached value is 0 or invalid.
        This ensures equity is correctly saved even on first initialization
        when there is no prior cache.
        """
        current_time = int(time.time() * 1000)
        
        # Always fetch fresh if:
        # 1. No previous cache exists
        # 2. Cache is invalid (0 or None)
        # 3. Cache is older than 60 seconds
        cached_equity = getattr(self, '_cached_equity', None)
        has_valid_cache = (
            cached_equity is not None and 
            cached_equity > 0 and
            hasattr(self, '_last_equity_fetch') and
            (current_time - self._last_equity_fetch) <= 60000
        )
        
        if not has_valid_cache:
            # Always fetch fresh from API - don't rely on potentially stale cache
            api_equity = self._get_api_equity()
            self._cached_equity = api_equity
            self._last_equity_fetch = current_time
            return api_equity
        else:
            return cached_equity
    
    def _load_risk_data_for_state(self) -> dict:
        """Load risk data from risk_state.json - Step 2 of state saving"""
        risk_data = {}
        try:
            risk_file = os.path.join(self.config.logs_path, "risk_state.json")
            if os.path.exists(risk_file):
                with open(risk_file, "r") as f:
                    raw_risk_data = json.load(f)
                    # Sanitize all numpy float32 values
                    for key, value in raw_risk_data.items():
                        if key == "positions":
                            # Sanitize positions dict
                            sanitized_positions = {}
                            for sym, pos_data in value.items():
                                if isinstance(pos_data, dict):
                                    sanitized_positions[sym] = {k: float(v) if hasattr(v, 'item') else v for k, v in pos_data.items()}
                                else:
                                    sanitized_positions[sym] = pos_data
                            risk_data[key] = sanitized_positions
                        elif hasattr(value, 'item'):  # numpy scalar
                            risk_data[key] = float(value)
                        else:
                            risk_data[key] = value
        except Exception as e:
            logger.warning(f"Could not read risk_state.json: {e}")
        return risk_data
    
    def _build_signals_data(self) -> dict:
        """Build signals data dictionary - Step 3 of state saving"""
        signals_data = {}
        for symbol, signal in self.last_signals.items():
            if signal:
                signals_data[symbol] = {
                    "action": signal.action.name if hasattr(signal.action, 'name') else str(signal.action),
                    "strength": float(signal.signal_strength) if hasattr(signal.signal_strength, 'item') else float(signal.signal_strength),
                    "confidence": float(signal.confidence) if hasattr(signal.confidence, 'item') else float(signal.confidence),
                    "price": float(signal.price) if hasattr(signal, 'price') and signal.price else 0.0
                }
        return signals_data
    
    def _sanitize_value(self, val):
        """Sanitize value - converts numpy types to native Python types"""
        if val is None:
            return None
        # Check for numpy types
        if hasattr(val, 'item'):  # numpy scalar (float32, int32, etc.)
            return float(val)
        elif hasattr(val, 'tolist'):  # numpy array
            return val.tolist()
        elif isinstance(val, dict):
            return {k: self._sanitize_value(v) for k, v in val.items()}
        elif isinstance(val, (list, tuple)):
            return [self._sanitize_value(v) for v in val]
        elif isinstance(val, (int, float)):
            # Handle Python int/float subclasses that might cause issues
            if isinstance(val, float) and (val != val or abs(val) == float('inf')):  # NaN or Inf
                return 0.0
            return val
        return val
    
    def _get_execution_tracker_summary(self) -> dict:
        """Get summary of execution tracker for state saving"""
        try:
            active_orders = self.trade_tracker.get_active_orders_summary()
            return {
                "total_signals": len(self.trade_tracker._signals),
                "total_orders": len(self.trade_tracker._orders),
                "active_orders": len(active_orders),
                "active_order_symbols": [o.get("symbol") for o in active_orders] if active_orders else []
            }
        except Exception as e:
            logger.warning(f"Could not get execution tracker summary: {e}")
            return {"error": str(e)}
    
    def _get_healing_metrics_for_state(self) -> dict:
        """Get healing metrics for state saving (sanitized)"""
        try:
            metrics = self._healing_metrics.copy()
            # Sanitize errors list - keep only last 10 errors
            if 'heal_errors' in metrics and isinstance(metrics['heal_errors'], list):
                metrics['heal_errors'] = metrics['heal_errors'][-10:]
            return self._sanitize_value(metrics)
        except Exception as e:
            logger.warning(f"Could not get healing metrics: {e}")
            return {"error": str(e)}
    
    def _get_circuit_breaker_status(self) -> dict:
        """Get circuit breaker status for state saving"""
        try:
            from api.aster_api import is_api_healthy, get_api_health_status
            return {
                "is_healthy": is_api_healthy(),
                "status": get_api_health_status()
            }
        except Exception as e:
            logger.warning(f"Could not get circuit breaker status: {e}")
            return {"is_healthy": True, "error": str(e)}
    
    def _build_state_data(self, api_equity: float, risk_data: dict, signals_data: dict, market_prices: dict) -> dict:
        """Build and sanitize state data - Step 5 of state saving"""
        # Sanitize all data
        sanitized_equity = self._sanitize_value(api_equity)
        sanitized_market = self._sanitize_value(market_prices)
        
        sanitized_risk_data = {}
        for key, value in risk_data.items():
            sanitized_risk_data[key] = self._sanitize_value(value)

        sanitized_signals = self._sanitize_value(signals_data)

        state_data = {
            "running": self.state.running,
            "start_time": self.state.start_time,
            "loop_count": self.state.loop_count,
            "last_feature_update": self.state.last_feature_update,
            "last_llm_review": self.state.last_llm_review,
            "trades_executed": self.state.trades_executed,
            "symbols": self.config.symbols,
            "intervals": self.config.intervals,
            # Equity from API (real-time)
            "equity": sanitized_equity,
            # Risk data from risk_state.json
            "daily_pnl": sanitized_risk_data.get("daily_pnl", 0.0),
            "drawdown_pct": sanitized_risk_data.get("drawdown_pct", 0.0),
            "open_positions": sanitized_risk_data.get("open_positions_count", 0),
            "positions": sanitized_risk_data.get("positions", {}),
            # Trading signals
            "last_signals": sanitized_signals,
            # Market data (current prices)
            "market": sanitized_market,
            # Execution tracker summary
            "execution_tracker": self._get_execution_tracker_summary(),
            # Healing metrics
            "healing_metrics": self._get_healing_metrics_for_state(),
            # Circuit breaker status
            "circuit_breaker": self._get_circuit_breaker_status(),
            "timestamp": int(time.time() * 1000)
        }
        
        # Final sanitization pass to catch any remaining numpy types
        return self._sanitize_value(state_data)
    
    def _write_state_to_file(self, state_data: dict):
        """Write state data to file - Step 6 of state saving"""
        # Use custom JSON encoder that handles numpy types automatically
        class NumpyEncoder(json.JSONEncoder):
            def default(self, obj):
                if hasattr(obj, 'item'):  # numpy scalar
                    return float(obj)
                elif hasattr(obj, 'tolist'):  # numpy array
                    return obj.tolist()
                return super().default(obj)
        
        state_file = os.path.join(self.config.logs_path, "v2_state.json")
        with open(state_file, "w") as f:
            json.dump(state_data, f, indent=2, cls=NumpyEncoder)
    
    async def _main_loop(self):
        """Loop principal del sistema"""
        logger.warning(f"🎯 [MAIN_LOOP] _main_loop() called! running={self.state.running}, loop_count={self.state.loop_count}")
        logger.info("🎯进入主循环 (Main loop started)")
        
        while self.state.running:
            self.state.loop_count += 1
            
            try:
                # 1. SYNC: Update equity and positions from API every loop (every 60 seconds)
                # Changed from every 5 minutes to ensure fresh position data for the position check
                # ALWAYS try to fetch equity (even if 0) to handle fresh start scenarios
                if self.state.loop_count % 1 == 0:  # Every loop (every 60 seconds)
                    api_equity = self._get_api_equity()
                    # Update equity regardless of value - allow 0 to be updated
                    # This ensures the system can recover after reset
                    if api_equity is not None:
                        self.risk_guard.update_equity(api_equity)
                        logger.debug(f"Equity updated: ${api_equity:.2f}")
                    
                    # Also sync positions with exchange to prevent stale position data
                    api_positions = self._get_api_positions()
                    if api_positions:
                        self.risk_guard.sync_with_exchange(api_positions)
                
                # 2. Verificar risk status
                risk_status = self.risk_guard.get_status()
                logger.info(f"[Loop {self.state.loop_count}] Risk: {risk_status['risk_level']}, Equity: ${risk_status['equity']:.2f}")
                
                # 2b. Check liquidation guard - emergency check for margin ratio
                if self.risk_guard and hasattr(self.risk_guard, 'check_liquidation_risk'):
                    liq_check = self.risk_guard.check_liquidation_risk()
                    if liq_check.get("at_risk"):
                        logger.critical(
                            f"🚨 LIQUIDATION GUARD ACTIVATED: {liq_check.get('message')} "
                            f"- Closing all positions!"
                        )
                        # Close all positions - would need to implement emergency close
                        # For now, just log the warning
                
                # 2c. Log to centralized logger for OpenClaw integration
                if self.centralized_logger:
                    try:
                        # Get market prices for logging
                        market_prices = self._get_market_prices()
                        
                        # Build positions dict from risk status
                        positions_data = risk_status.get("positions", {})
                        
                        # Build signals dict
                        signals_data = {}
                        for symbol, signal in self.last_signals.items():
                            if signal:
                                signals_data[symbol] = {
                                    "action": signal.action.name if hasattr(signal.action, 'name') else str(signal.action),
                                    "strength": float(signal.signal_strength) if hasattr(signal.signal_strength, 'item') else float(signal.signal_strength),
                                    "confidence": float(signal.confidence) if hasattr(signal.confidence, 'item') else float(signal.confidence),
                                }
                        
                        # Log heartbeat
                        self.centralized_logger.log_heartbeat(
                            running=self.state.running,
                            equity=risk_status.get("equity", 0.0),
                            positions=positions_data,
                            signals=signals_data,
                            market=market_prices,
                            loop_count=self.state.loop_count,
                            trades_executed=self.state.trades_executed,
                            risk_level=risk_status.get("risk_level", "NORMAL")
                        )
                        
                        # Log equity
                        self.centralized_logger.log_equity(
                            equity=risk_status.get("equity", 0.0),
                            daily_pnl=risk_status.get("daily_pnl", 0.0),
                            drawdown_pct=risk_status.get("drawdown_pct", 0.0)
                        )
                        
                        # Log risk
                        self.centralized_logger.log_risk(
                            risk_level=risk_status.get("risk_level", "NORMAL"),
                            equity=risk_status.get("equity", 0.0),
                            max_position_pct=self.risk_guard.config.max_position_pct,
                            current_exposure_pct=risk_status.get("exposure_pct", 0.0),
                            daily_loss_pct=risk_status.get("daily_loss_pct", 0.0),
                            drawdown_pct=risk_status.get("drawdown_pct", 0.0),
                            open_positions_count=risk_status.get("open_positions_count", 0),
                            trades_today=risk_status.get("trades_today", 0),
                            can_trade=risk_status.get("can_trade", True)
                        )
                    except Exception as e:
                        logger.error(f"Error logging to centralized logger: {e}")
                
                # 3. Verificar si hay señales de trading
                await self._process_signals()
                
                # 3. Verificar si debe hacer LLM review
                await self._process_llm_review()
                
                # 4. Verificar scale-in opportunities (every 5 minutes = every 5th loop)
                if self.state.loop_count % 5 == 0:
                    await self._process_scale_in()
                
                # 5. Dynamic Risk Adjustment (every 3 hours = every 180th loop)
                # This uses LLM to analyze performance and adjust risk parameters
                if self.state.loop_count % 180 == 0:
                    await self._process_risk_adjustment()
                
                # 5b. SELF-HEAL: Check positions for missing SL/TP and wrong leverage
                # CRITICAL: Run on EVERY loop to immediately fix exchange state mismatches
                # This is essential for safety - exchange must always match trading logic
                await self._self_heal_positions()
                
                # 6. Save state after each loop iteration (for dashboard visibility)
                self._save_state()
                
                # 7. Esperar
                await asyncio.sleep(self.config.main_loop_seconds)
                
            except Exception as e:
                logger.error(f"Error en loop: {e}")
                self.state.errors.append(str(e))
                await asyncio.sleep(10)
    
    async def _process_signals(self):
        """Procesa señales de trading"""
        if not self.feature_calculator or not self.signal_generator:
            return
        
        for symbol in self.config.symbols:
            try:
                # Obtener order book
                order_book = None
                if self.ws_manager:
                    ob = self.ws_manager.get_order_book(symbol)
                    if ob:
                        order_book = {
                            "bids": [[p, q] for p, q in ob.bids],
                            "asks": [[p, q] for p, q in ob.asks]
                        }
                
                # Obtener trades recientes
                trades = []
                if self.ws_manager:
                    recent = self.ws_manager.get_recent_trades(symbol, 100)
                    trades = [{"quantity": t.quantity, "is_buyer_maker": t.is_buyer_maker} for t in recent]
                
                # Calcular features
                try:
                    features = self.feature_calculator.calculate_all_features(
                        symbol, 
                        order_book=order_book,
                        trades=trades
                    )
                except Exception as fe:
                    logger.error(f"Error calculando features para {symbol}: {fe}")
                    continue
                
                # Agregar precio actual - usar order_book o fallback a último kline
                price = 0.0
                if order_book and order_book.get("bids"):
                    price = float(order_book["bids"][0][0])
                else:
                    # Fallback: usar precio del último kline histórico
                    try:
                        klines = self.feature_calculator.price_history.get(symbol, {}).get("1m", [])
                        if klines and len(klines) > 0:
                            # Handle both list and deque types
                            last_kline = klines[-1] if hasattr(klines, '__getitem__') else None
                            if last_kline and isinstance(last_kline, dict):
                                price = float(last_kline.get("close", 0))
                    except Exception as e:
                        logger.warning(f"Error getting price from klines for {symbol}: {e}")
                
                if not features:
                    logger.warning(f"Features vacíos para {symbol}, saltando...")
                    continue
                
                # Convertir features a dict y añadir precio
                try:
                    features_dict = features.to_dict()
                    features_dict["price"] = price
                except Exception as fe2:
                    import traceback
                    logger.error(f"Error en to_dict para {symbol}: {fe2}")
                    logger.error(traceback.format_exc())
                    continue
                
                # Guardar features
                self.current_features[symbol] = features_dict
                
                # Generar señal ML
                try:
                    signal = self.signal_generator.predict(features_dict)
                except Exception as se:
                    logger.error(f"Error en predict para {symbol}: {se}")
                    continue
                    
                self.last_signals[symbol] = signal
                
                # Log señal
                logger.info(f"  {symbol}: {signal.action.name} (strength={signal.signal_strength:.2f}, conf={signal.confidence:.2f})")
                
                # Si hay señal clara, verificar risk y ejecutar
                # Lowered threshold from 0.5 to 0.10 to allow more signals through
                if signal.action.name != "HOLD" and signal.signal_strength > 0.10:
                    await self._evaluate_trade(symbol, signal, features.to_dict())
                
            except Exception as e:
                import traceback
                logger.error(f"Error procesando {symbol}: {e}")
                logger.error(f"Traceback: {traceback.format_exc()}")
                # Continue processing other symbols even if one fails
    
    async def _evaluate_trade(self, symbol: str, signal: TradingSignal, features: Dict):
        """Evalúa si ejecutar un trade - CON LOG DETALLADO DE SEÑALES Y DECISIONES"""
        
        # ═══════════════════════════════════════════════════════════════════════════════
        # 📋 TRADES AND SIGNALS LOG - Signal Received
        # ═══════════════════════════════════════════════════════════════════════════════
        logger.info("=" * 80)
        logger.info(f"📋 SIGNAL RECIBIDO | {symbol} | {signal.action.name} | ${signal.price:.4f}")
        logger.info(f"   Timestamp: {signal.timestamp if hasattr(signal, 'timestamp') else 'N/A'}")
        logger.info(f"   Interval: {signal.interval if hasattr(signal, 'interval') else 'N/A'}")
        if features:
            logger.info(f"   Features: {list(features.keys())[:5]}")  # First 5 features
        logger.info("=" * 80)
        
        # CRITICAL: Check if position already exists for this symbol
        # Query exchange positions directly to ensure we have fresh data
        existing_positions = self._get_api_positions()
        if symbol in existing_positions:
            logger.warning(f"Position already exists for {symbol}, skipping trade")
            logger.info(f"   ❌ SEÑAL BLOQUEADA: Posición existente para {symbol}")
            logger.info(f"   Reason: Ya existe una posición abierta")
            return None
        
        # Load symbol-specific config for leverage and min_notional
        config_path = self.config.config_path + "/risk_config.json"
        symbol_config = {}
        try:
            if os.path.exists(config_path):
                with open(config_path, "r") as f:
                    config_data = json.load(f)
                    symbol_config = config_data.get("symbols", {}).get(symbol, {})
        except Exception as e:
            logger.warning(f"Could not load risk_config for {symbol}: {e}")
        
        # Get leverage and min_notional from config (default to 5x and $5.0)
        leverage = symbol_config.get("max_leverage", 5)
        min_notional = symbol_config.get("min_notional_usdt", 8.0)
        
        # CRITICAL FIX: Enforce hard caps at trade execution time
        # These cannot be bypassed by config errors
        
        # Get equity FIRST before using it
        risk_status = self.risk_guard.get_status()
        equity = risk_status["equity"]
        
        # FIX #2: Dynamic leverage cap based on equity - SAFE for small accounts
        # For $40 equity, 16x leverage is extremely dangerous ($640 exposure on $40!)
        # Apply equity-based leverage caps:
        # - Equity < $100: max 3x leverage
        # - Equity < $500: max 5x leverage
        # - Equity >= $500: max 10x leverage (lowered from 15x for safety)
        if equity < 100:
            HARD_MAX_LEVERAGE = 3
            logger.warning(f"⚠️ SMALL ACCOUNT PROTECTION: Equity ${equity:.2f} < $100, capping leverage at {HARD_MAX_LEVERAGE}x")
        elif equity < 500:
            HARD_MAX_LEVERAGE = 5
            logger.warning(f"⚠️ MEDIUM ACCOUNT PROTECTION: Equity ${equity:.2f} < $500, capping leverage at {HARD_MAX_LEVERAGE}x")
        else:
            HARD_MAX_LEVERAGE = 10  # Lowered from 15x for safety on all accounts
        
        HARD_MIN_NOTIONAL = 8.0
        
        # Cap leverage at maximum allowed
        if leverage > HARD_MAX_LEVERAGE:
            logger.warning(f"⚠️ LEVERAGE CAP: {leverage}x -> {HARD_MAX_LEVERAGE}x")
            leverage = HARD_MAX_LEVERAGE
        
        # Ensure minimum notional is never below safety threshold
        if min_notional < HARD_MIN_NOTIONAL:
            logger.warning(f"⚠️ MIN_NOTIONAL CAP: ${min_notional} -> ${HARD_MIN_NOTIONAL}")
            min_notional = HARD_MIN_NOTIONAL
        
        # Calcular tamaño de posición
        
        # Calculate position with leverage applied
        max_position_equity = equity * self.risk_guard.config.max_position_pct * risk_status["position_multiplier"]
        max_position_with_leverage = max_position_equity * leverage
        
        logger.info(f"  📊 EVALUACIÓN DE RIESGO:")
        logger.info(f"     Equity: ${equity:.2f}")
        logger.info(f"     Max position %: {self.risk_guard.config.max_position_pct*100:.1f}%")
        logger.info(f"     Position multiplier: {risk_status['position_multiplier']:.2f}x")
        logger.info(f"     Base position (before leverage): ${max_position_equity:.2f}")
        logger.info(f"     Leverage: {leverage}x")
        logger.info(f"     Leveraged position: ${max_position_with_leverage:.2f}")
        logger.info(f"     Min notional required: ${min_notional:.2f}")
        
        # Verificar con risk guard - pass leverage and min_notional
        result = self.risk_guard.check_trade(
            symbol=symbol,
            side=signal.action.name,
            notional=max_position_equity,  # Pass base notional (before leverage)
            entry_price=signal.price,
            current_price=signal.price,
            leverage=leverage,
            min_notional=min_notional
        )
        
        if not result.approved:
            # ═══════════════════════════════════════════════════════════════════════════════
            # ❌ TRADE BLOCKED - Detailed Reason
            # ═══════════════════════════════════════════════════════════════════════════════
            logger.info("=" * 80)
            logger.info(f"❌ SEÑAL BLOQUEADA | {symbol} | {signal.action.name}")
            logger.info("=" * 80)
            logger.info(f"   📍 RAZÓN DE BLOQUEO:")
            
            # Parse and log detailed blocking reason
            reason = result.reason
            if "Circuit breaker" in reason:
                logger.info(f"      • Tipo: CIRCUIT BREAKER ACTIVO")
                logger.info(f"      • El sistema de trading está temporalmente desactivado debido a errores recientes")
                logger.info(f"      • Acción: Esperar a que se recupere el circuit breaker")
            elif "Pérdida diaria máxima" in reason or "daily" in reason.lower():
                logger.info(f"      • Tipo: LÍMITE DE PÉRDIDA DIARIA")
                logger.info(f"      • La pérdida diaria ha alcanzado el límite permitido")
                logger.info(f"      • Revisar: max_daily_loss_pct en configuración")
            elif "Pérdida semanal" in reason or "weekly" in reason.lower():
                logger.info(f"      • Tipo: LÍMITE DE PÉRDIDA SEMANAL")
                logger.info(f"      • La pérdida semanal ha alcanzado el límite permitido")
                logger.info(f"      • Revisar: max_weekly_loss_pct en configuración")
            elif "Drawdown máximo" in reason or "drawdown" in reason.lower():
                logger.info(f"      • Tipo: DRAWDOWN MÁXIMO")
                logger.info(f"      • El drawdown ha alcanzado el límite permitido")
                logger.info(f"      • Revisar: max_drawdown_pct en configuración")
            elif "Límite de trades diarios" in reason or "trades_today" in reason:
                logger.info(f"      • Tipo: LÍMITE DE TRADES DIARIOS")
                logger.info(f"      • Se ha alcanzado el número máximo de trades por día")
                logger.info(f"      • Revisar: max_trades_per_day en configuración")
            elif "Cooldown activo" in reason or "cooldown" in reason.lower():
                logger.info(f"      • Tipo: COOLDOWN ACTIVO")
                logger.info(f"      • Tiempo mínimo entre trades no ha transcurrido")
                logger.info(f"      • Revisar: min_trade_interval_minutes en configuración")
            elif "Insuficiente equity" in reason:
                logger.info(f"      • Tipo: EQUITY INSUFICIENTE")
                logger.info(f"      • No hay suficiente capital para operar")
                logger.info(f"      • Revisar: min_notional y equity disponible")
            elif "equity" in reason.lower() and "inválido" in reason.lower():
                logger.info(f"      • Tipo: EQUITY INVÁLIDO")
                logger.info(f"      • El equity es cero o inválido")
                logger.info(f"      • Revisar: Conexión con API y balance de cuenta")
            else:
                logger.info(f"      • Tipo: BLOQUEO GENÉRICO")
                logger.info(f"      • Razón: {reason}")
            
            logger.info(f"   📊 Detalles adicionales:")
            logger.info(f"      • Risk level: {result.risk_level.name if hasattr(result, 'risk_level') else 'N/A'}")
            logger.info(f"      • Equity: ${equity:.2f}")
            logger.info(f"      • Leverage: {leverage}x")
            logger.info(f"      • Min notional: ${min_notional:.2f}")
            logger.info("=" * 80)
            return
        
        # Ajustar tamaño si es necesario
        adjusted_notional = max_position_equity * result.position_size_multiplier
        
        # ═══════════════════════════════════════════════════════════════════════════════
        # ✅ TRADE APPROVED BY RISK - Now do LLM review BEFORE execution
        # ═══════════════════════════════════════════════════════════════════════════════
        logger.info("=" * 80)
        logger.info(f"✅ SEÑAL APROBADA POR RISK | {symbol} | {signal.action.name}")
        logger.info("=" * 80)
        
        # CRITICAL FIX #1: LLM Review MUST happen BEFORE trade execution
        # The LLM guardian acts as a final checkpoint - if it says HOLD, we don't trade
        llm_approved = True
        llm_decision = "APPROVED"
        llm_reason = "No LLM review needed"
        
        if self.llm_guardian:
            try:
                # Check if LLM should review this signal
                if self.llm_guardian.should_review(signal.__dict__, features):
                    logger.info(f"   🔍 Solicitando revisión LLM PARA {symbol} ANTES de ejecutar...")
                    
                    # Call LLM for final approval
                    llm_result = await self.llm_guardian.review_signal(signal.__dict__, features)
                    llm_decision = llm_result.decision.name
                    llm_reason = llm_result.reason
                    
                    logger.info(f"   📝 Decisión LLM: {llm_decision} - {llm_reason}")
                    
                    if llm_result.decision == ReviewDecision.REJECT:
                        llm_approved = False
                        logger.warning(f"   🛑 LLM RECHAZÓ la señal para {symbol}!")
                        logger.warning(f"   🛑 Trade BLOQUEADO por LLM Guardian")
                        logger.info("=" * 80)
                        return None  # DON'T execute trade - LLM said HOLD/REJECT
                    else:
                        logger.info(f"   ✅ LLM APROBÓ la señal para {symbol}")
                else:
                    logger.debug(f"   ⏭️ LLM review no necesaria para {symbol} (within cooldown)")
            except Exception as e:
                logger.warning(f"   ⚠️ Error en revisión LLM: {e}")
                # FIXED: On LLM error, we proceed with trade (fail open) but log warning
                logger.warning(f"   ⚠️ Operando con error de LLM - continuando con trade")
        
        # Only proceed if LLM approved (or no LLM available)
        if not llm_approved:
            logger.info(f"   ❌ Trade cancelado para {symbol} - LLM dijo {llm_decision}")
            return None
        
        # ═══════════════════════════════════════════════════════════════════════════════
        # 🚀 EXECUTING TRADE (LLM Approved)
        # ═══════════════════════════════════════════════════════════════════════════════
        logger.info(f"   📊 Detalles del trade:")
        logger.info(f"      • Side: {signal.action.name}")
        logger.info(f"      • Entry price: ${signal.price:.4f}")
        logger.info(f"      • Notional original: ${max_position_equity:.2f}")
        logger.info(f"      • Notional ajustado: ${adjusted_notional:.2f}")
        logger.info(f"      • Leverage: {leverage}x")
        logger.info(f"      • Position multiplier: {result.position_size_multiplier:.2f}x")
        if result.reason:
            logger.info(f"      • Nota: {result.reason}")
        logger.info("   🚀 Ejecutando trade...")
        logger.info("=" * 80)
        
        # Ejecutar el trade via API
        await self._execute_trade(symbol, signal.action.name, adjusted_notional, signal.price)
        
        # Actualizar risk guard
        self.risk_guard.on_trade_executed(
            symbol=symbol,
            side=signal.action.name,
            notional=adjusted_notional,
            entry_price=signal.price,
            pnl=0  # Por ahora sin P&L
        )
        
        self.state.trades_executed += 1
        
        logger.info(f"   ✅ Trade ejecutado exitosamente para {symbol} {signal.action.name}")
    
    async def _execute_trade(self, symbol: str, side: str, notional: float, price: float):
        """Ejecuta el trade via API de Aster - Matching V1 open_position.py implementation
        
        This function coordinates the trade execution by calling sub-functions for each step.
        Includes circuit breaker checks and trade execution tracking with correlation IDs.
        """
        # Import circuit breaker functions
        from api.aster_api import is_api_healthy, get_api_health_status
        
        # Step 0: Check circuit breaker BEFORE placing order
        if not is_api_healthy():
            cb_status = get_api_health_status()
            logger.error(f"⛔ Circuit breaker OPEN - rejecting order for {symbol}")
            logger.error(f"   Circuit breaker status: {cb_status}")
            
            # Track failed order
            correlation_id = self.trade_tracker.create_correlation_id(symbol)
            self.trade_tracker.update_order_status(
                correlation_id, 
                OrderStatus.ORDER_FAILED,
                error="Circuit breaker open - order rejected"
            )
            return None
        
        # Create correlation ID for tracking the order lifecycle
        correlation_id = self.trade_tracker.create_correlation_id(symbol)
        logger.info(f"📋 Created correlation ID for trade: {correlation_id}")
        
        try:
            # Update status to ORDER_SENT when starting order placement
            self.trade_tracker.update_order_status(correlation_id, OrderStatus.ORDER_SENT)
            
            # Step 1: Set leverage
            leverage = await self._set_leverage(symbol)
            
            # Step 2: Get mark price
            mark_price = await self._get_mark_price(symbol, price)
            
            # Step 3: Calculate quantity with lot size validation
            quantity = self._calculate_quantity(notional, mark_price, symbol)
            
            # Step 4: Adjust quantity for min notional
            adj_qty, notional_real = self._adjust_quantity_for_min_notional(
                symbol, quantity, mark_price
            )
            
            if adj_qty <= 0:
                logger.error(f"  ❌ Quantity below LOT_SIZE min for {symbol}")
                return
            
            logger.info(f"  📊 {symbol}: Entry price ~ {mark_price:.6f}, qty {adj_qty:.8f}, notional {notional_real:.4f} USDT")
            
            # Step 5: Prepare and place main order
            result = await self._place_main_order(symbol, side, adj_qty)
            
            if result and "orderId" in result:
                # Update status to ORDER_CONFIRMED
                order_id = str(result.get('orderId'))
                self.trade_tracker.update_order_status(
                    correlation_id, 
                    OrderStatus.ORDER_CONFIRMED, 
                    order_id=order_id
                )
                
                logger.info(f"  ✅ Orden ejecutada: ID={result.get('orderId')}, precio={result.get('price')}")
                
                # Update status to ORDER_FILLED (market orders fill immediately)
                self.trade_tracker.update_order_status(
                    correlation_id, 
                    OrderStatus.ORDER_FILLED
                )
                
                # Step 6: Place SL/TP bracket orders
                entry_price = float(result.get("avgPrice", mark_price))
                if entry_price == 0.0:
                    entry_price = mark_price
                
                await self._place_stop_loss(symbol, side, adj_qty, entry_price)
                await self._place_take_profit_orders(symbol, side, adj_qty, entry_price)
                
                # Step 7: Log trade result
                await self._log_trade_result(symbol, side, adj_qty, entry_price, notional_real, result, "FILLED")
            else:
                # Update status to ORDER_FAILED
                error_msg = str(result) if result else "Unknown error"
                self.trade_tracker.update_order_status(
                    correlation_id, 
                    OrderStatus.ORDER_FAILED,
                    error=error_msg
                )
                logger.warning(f"  ⚠️ Orden response: {result}")
                await self._log_trade_result(symbol, side, adj_qty, mark_price, notional_real, result, "ERROR")
                
        except Exception as e:
            # Track error
            self.trade_tracker.update_order_status(
                correlation_id, 
                OrderStatus.ORDER_FAILED,
                error=str(e)
            )
            logger.error(f"  ❌ Error ejecutando orden: {e}")
    
    async def _set_leverage(self, symbol: str) -> int:
        """Set leverage for the symbol - Step 1 of trade execution"""
        from api.aster_api import set_leverage
        import math
        
        leverage = 5  # Default leverage
        config_path = os.path.join(self.config.config_path, "risk_config.json")
        try:
            if os.path.exists(config_path):
                with open(config_path, "r") as f:
                    config_data = json.load(f)
                    leverage = config_data.get("symbols", {}).get(symbol, {}).get("max_leverage", 5)
        except Exception as e:
            logger.warning(f"Could not read leverage config: {e}")
        
        set_leverage(symbol, leverage)
        logger.info(f"  📊 Set leverage to {leverage}x for {symbol}")
        return leverage
    
    async def _get_mark_price(self, symbol: str, fallback_price: float) -> float:
        """Get mark price from exchange - Step 2 of trade execution"""
        from api.aster_api import public_get
        
        mark_data = public_get("/fapi/v1/premiumIndex", {"symbol": symbol})
        if isinstance(mark_data, list) and mark_data:
            mark_data = mark_data[0]
        mark_price = float(mark_data.get("markPrice", "0")) if mark_data else 0.0
        
        if mark_price <= 0:
            logger.warning(f"  ⚠️ Invalid markPrice for {symbol}, using signal price {fallback_price}")
            mark_price = fallback_price
        
        logger.info(f"  📊 Mark price: {mark_price:.6f}")
        return mark_price
    
    def _calculate_quantity(self, notional: float, mark_price: float, symbol: str) -> float:
        """Calculate quantity with lot size validation - Step 3 of trade execution"""
        from api.aster_api import get_exchange_info
        import math
        
        quantity = notional / mark_price
        
        # Get lot size filters and adjust
        try:
            info = get_exchange_info()
            filters = info.get("symbols", [])
            symbol_filters = None
            for s in filters:
                if s.get("symbol") == symbol:
                    symbol_filters = s.get("filters", [])
                    break
            
            if symbol_filters:
                min_qty = step_size = None
                for f in symbol_filters:
                    if f.get("filterType") == "LOT_SIZE":
                        min_qty = float(f["minQty"])
                        step_size = float(f["stepSize"])
                        break
                
                if min_qty is not None and step_size is not None:
                    # Use math.ceil to round UP (like v1 does) to meet minimum lot size
                    steps = math.ceil(quantity / step_size - 1e-9)
                    adj = steps * step_size
                    if adj < min_qty:
                        adj = min_qty
                    quantity = float(f"{adj:.8f}")
        except Exception as e:
            logger.warning(f"Could not adjust quantity to lot size: {e}")
        
        return quantity
    
    def _adjust_quantity_for_min_notional(self, symbol: str, quantity: float, mark_price: float) -> tuple:
        """Adjust quantity to meet minimum notional requirement - Step 4 of trade execution"""
        from api.aster_api import get_exchange_info
        import math
        
        notional_real = mark_price * quantity
        MIN_NOTIONAL = 5.0
        
        if notional_real < MIN_NOTIONAL:
            logger.warning(f"  ⚠️ Notional {notional_real:.2f} below minimum {MIN_NOTIONAL}, adjusting...")
            target_qty = MIN_NOTIONAL / mark_price
            
            try:
                info = get_exchange_info()
                filters = info.get("symbols", [])
                symbol_filters = None
                for s in filters:
                    if s.get("symbol") == symbol:
                        symbol_filters = s.get("filters", [])
                        break
                
                if symbol_filters:
                    for f in symbol_filters:
                        if f.get("filterType") == "LOT_SIZE":
                            min_qty = float(f["minQty"])
                            step_size = float(f["stepSize"])
                            # Use math.ceil to round UP (like v1 does)
                            steps = math.ceil(target_qty / step_size - 1e-9)
                            quantity = steps * step_size
                            if quantity < min_qty:
                                quantity = min_qty
                            logger.info(f"  📊 Rounded up qty to meet min notional: {quantity:.8f}")
                            break
            except Exception as e:
                logger.warning(f"  ⚠️ Could not get lot size filters: {e}")
                quantity = target_qty
            
            notional_real = mark_price * quantity
        else:
            quantity = quantity
        
        return quantity, notional_real
    
    async def _place_main_order(self, symbol: str, side: str, quantity: float) -> dict:
        """Place the main market order - Step 5 of trade execution"""
        from api.aster_api import place_order
        
        side_str = "BUY" if side == "BUY" else "SELL"
        
        order_params = {
            "symbol": symbol,
            "side": side_str,
            "type": "MARKET",
            "quantity": f"{quantity:.8f}"
        }
        
        logger.info(f"  📤 Enviando orden: {order_params}")
        result = place_order(order_params)
        return result
    
    def _get_tick_size(self, symbol: str) -> float:
        """Get the tick size (price precision) for a symbol from exchange info"""
        from api.aster_api import get_exchange_info
        try:
            info = get_exchange_info()
            for s in info.get('symbols', []):
                if s['symbol'] == symbol:
                    for f in s.get('filters', []):
                        if f.get('filterType') == 'PRICE_FILTER':
                            return float(f.get('tickSize', '0.01'))
            return 0.01  # Default
        except Exception:
            return 0.01  # Default
    
    def _round_to_tick_size(self, price: float, tick_size: float) -> float:
        """Round price to the nearest tick size, with proper precision handling"""
        if tick_size <= 0:
            return price
        # First round to tick size
        rounded = round(price / tick_size) * tick_size
        # Then format to a reasonable number of decimal places to avoid floating point errors
        # like 1876.1000000000001
        tick_str = f'{tick_size:.10f}'.rstrip('0')
        decimal_places = len(tick_str.split('.')[-1]) if '.' in tick_str else 0
        return round(rounded, decimal_places)
    
    async def _place_stop_loss(self, symbol: str, side: str, quantity: float, entry_price: float):
        """Place stop loss order - Step 6a of trade execution"""
        from api.aster_api import place_order
        
        sl_pct = self._get_sl_tp_percentage(symbol, "sl_pct", 1.5)
        sl_factor = sl_pct / 100.0
        
        # For LONG: SL below entry. For SHORT: SL above entry
        if side == "BUY":
            sl_price = entry_price * (1.0 - sl_factor)
        else:
            sl_price = entry_price * (1.0 + sl_factor)
        
        # Round to tick size
        tick_size = self._get_tick_size(symbol)
        sl_price = self._round_to_tick_size(sl_price, tick_size)
        
        close_side = "SELL" if side == "BUY" else "BUY"
        
        try:
            sl_params = {
                "symbol": symbol,
                "side": close_side,
                "type": "STOP_MARKET",
                "stopPrice": f"{sl_price:.8f}",
                "reduceOnly": "true",
                "quantity": f"{quantity:.8f}",
                "workingType": "MARK_PRICE"
            }
            logger.info(f"  📊 Placing SL: side={close_side}, stopPrice={sl_price} (tick={tick_size}), qty={quantity}")
            sl_order = place_order(sl_params)
            if sl_order and 'orderId' in sl_order:
                logger.info(f"  ✅ SL placed: {sl_order.get('orderId')}")
                return sl_order
            else:
                logger.warning(f"  ⚠️ SL order failed: {sl_order}")
                return sl_order  # Return the error for self-healing to detect
        except Exception as e:
            logger.warning(f"  ⚠️ Failed to place SL: {e}")
            return {"error": str(e)}
    
    async def _place_take_profit_orders(self, symbol: str, side: str, quantity: float, entry_price: float):
        """Place take profit orders (TP1 and TP2) - Step 6b of trade execution"""
        from api.aster_api import place_order
        
        tp1_pct = self._get_sl_tp_percentage(symbol, "tp1_pct", 1.5)
        tp2_pct = self._get_sl_tp_percentage(symbol, "tp2_pct", 3.0)
        
        tp1_factor = tp1_pct / 100.0
        tp2_factor = tp2_pct / 100.0
        
        close_side = "SELL" if side == "BUY" else "BUY"
        
        # Get tick size for this symbol
        tick_size = self._get_tick_size(symbol)
        
        if side == "BUY":
            tp1_price = self._round_to_tick_size(entry_price * (1.0 + tp1_factor), tick_size)
            tp2_price = self._round_to_tick_size(entry_price * (1.0 + tp2_factor), tick_size)
        else:
            tp1_price = self._round_to_tick_size(entry_price * (1.0 - tp1_factor), tick_size)
            tp2_price = self._round_to_tick_size(entry_price * (1.0 - tp2_factor), tick_size)
        
        # Place TP1 (50% of position)
        try:
            tp1_qty = quantity * 0.5
            tp1_qty = self._adjust_qty_to_lot(symbol, tp1_qty)
            if tp1_qty > 0:
                tp1_params = {
                    "symbol": symbol,
                    "side": close_side,
                    "type": "TAKE_PROFIT_MARKET",
                    "stopPrice": f"{tp1_price:.4f}",
                    "reduceOnly": "true",
                    "quantity": f"{tp1_qty:.8f}",
                    "workingType": "MARK_PRICE"
                }
                tp1_order = place_order(tp1_params)
                if tp1_order and tp1_order.get('orderId'):
                    logger.info(f"  ✅ TP1 placed: {tp1_order.get('orderId')}")
                else:
                    logger.warning(f"  ⚠️ TP1 order failed: {tp1_order}")
        except Exception as e:
            logger.warning(f"  ⚠️ Failed to place TP1: {e}")
        
        # Place TP2 (remaining 50% of position)
        try:
            tp2_qty = quantity * 0.5
            tp2_qty = self._adjust_qty_to_lot(symbol, tp2_qty)
            if tp2_qty > 0:
                tp2_params = {
                    "symbol": symbol,
                    "side": close_side,
                    "type": "TAKE_PROFIT_MARKET",
                    "stopPrice": f"{tp2_price:.4f}",
                    "reduceOnly": "true",
                    "quantity": f"{tp2_qty:.8f}",
                    "workingType": "MARK_PRICE"
                }
                tp2_order = place_order(tp2_params)
                if tp2_order and tp2_order.get('orderId'):
                    logger.info(f"  ✅ TP2 placed: {tp2_order.get('orderId')}")
                else:
                    logger.warning(f"  ⚠️ TP2 order failed: {tp2_order}")
        except Exception as e:
            logger.warning(f"  ⚠️ Failed to place TP2: {e}")
    
    def _get_sl_tp_percentage(self, symbol: str, config_key: str, default: float) -> float:
        """Get SL/TP percentage from config with validation"""
        sl_pct = default
        config_path = os.path.join(self.config.config_path, "risk_config.json")
        try:
            if os.path.exists(config_path):
                with open(config_path, "r") as f:
                    config_data = json.load(f)
                    raw_value = config_data.get("symbols", {}).get(symbol, {}).get(config_key, default)
                    
                    # Validate the percentage
                    try:
                        val = float(raw_value)
                        min_val, max_val = 0.1, 50.0 if config_key == "sl_pct" else 100.0
                        if val < min_val or val > max_val:
                            logger.warning(f"  ⚠️ Invalid {config_key} {val}% (must be {min_val}-{max_val}%), using default {default}%")
                            sl_pct = default
                        else:
                            sl_pct = val
                    except (TypeError, ValueError):
                        logger.warning(f"  ⚠️ Non-numeric {config_key} '{raw_value}', using default {default}%")
                        sl_pct = default
        except Exception:
            pass
        
        return sl_pct
    
    def _adjust_qty_to_lot(self, symbol: str, qty: float) -> float:
        """Adjust quantity to meet lot size requirements"""
        from api.aster_api import get_exchange_info
        
        try:
            info = get_exchange_info()
            filters = info.get("symbols", [])
            symbol_filters = None
            for s in filters:
                if s.get("symbol") == symbol:
                    symbol_filters = s.get("filters", [])
                    break
            
            if not symbol_filters:
                return qty
            
            min_qty = step_size = None
            for f in symbol_filters:
                if f.get("filterType") == "LOT_SIZE":
                    min_qty = float(f["minQty"])
                    step_size = float(f["stepSize"])
                    break
            
            if min_qty is None or step_size is None:
                return qty
            
            import math
            steps = math.ceil(qty / step_size - 1e-9)
            adj = steps * step_size
            if adj < min_qty:
                adj = min_qty
            return float(f"{adj:.8f}")
        except Exception:
            return qty
    
    async def _log_trade_result(self, symbol: str, side: str, quantity: float, 
                                 price: float, notional: float, result: dict, status: str):
        """Log trade result to centralized logger - Step 7 of trade execution"""
        if self.centralized_logger:
            try:
                side_str = "BUY" if side == "BUY" else "SELL"
                self.centralized_logger.log_trade(
                    symbol=symbol,
                    side=side_str,
                    quantity=quantity,
                    price=price,
                    notional=notional,
                    status=status,
                    order_id=str(result.get("orderId")) if result else "N/A",
                    error=str(result) if status == "ERROR" else None
                )
            except Exception as e:
                logger.error(f"Error logging trade to centralized logger: {e}")
    
    async def _process_llm_review(self):
        """Procesa revisión con LLM"""
        if not self.llm_guardian or not self.current_features:
            return
        
        # Revisar solo si hay señales
        for symbol, signal in self.last_signals.items():
            features = self.current_features.get(symbol, {})
            
            if not features:
                continue
            
            # Verificar si debe revisar
            if self.llm_guardian.should_review(signal.__dict__, features):
                logger.info(f"  🔍 Revisión LLM para {symbol}...")
                
                # FIXED Issue #10: Add error handling for LLM review to prevent silent failures
                try:
                    result = await self.llm_guardian.review_signal(signal.__dict__, features)
                    logger.info(f"     Decisión: {result.decision.name} - {result.reason}")
                    
                    # Si LLM rechaza, no ejecutar
                    if result.decision == ReviewDecision.REJECT:
                        logger.warning(f"  ⚠️ LLM rechazó señal para {symbol}")
                except Exception as e:
                    logger.error(f"  ❌ Error en revisión LLM para {symbol}: {e}")
                    # Continue with trade execution on LLM error (fail open for trading)
    
    async def _process_scale_in(self):
        """Process scale-in opportunities for existing positions."""
        try:
            # Get scale-in state
            scale_state = get_scale_in_state()
            
            # Check if any positions have TP2 hit (this would be updated by order fills)
            # For now, we'll check the scale-in conditions
            
            logger.info("  🔄 Checking scale-in opportunities...")
            
            # Run scale-in check
            results = await process_scale_in()
            
            if results:
                for result in results:
                    symbol = result.get("symbol", "UNKNOWN")
                    check = result.get("check_result", {})
                    exec_result = result.get("execution_result", {})
                    
                    if exec_result.get("success"):
                        logger.info(
                            f"  ✅ Scale-in executed for {symbol}: "
                            f"+{exec_result.get('added_qty', 0):.8f} "
                            f"@ notional ${exec_result.get('added_notional', 0):.2f}"
                        )
                        
                        # Log to centralized logger
                        if self.centralized_logger:
                            try:
                                self.centralized_logger.log_trade(
                                    symbol=symbol,
                                    side=exec_result.get("side", "BUY"),
                                    quantity=exec_result.get("added_qty", 0),
                                    price=0,  # Market order
                                    notional=exec_result.get("added_notional", 0),
                                    status="SCALE_IN_FILLED",
                                    order_id=str(exec_result.get("order_id", ""))
                                )
                            except Exception as e:
                                logger.error(f"Error logging scale-in: {e}")
                    else:
                        logger.debug(f"  ⏭️ Scale-in skipped for {symbol}: {check.get('reason', 'unknown')}")
            else:
                logger.debug("  No scale-in opportunities found")
                
        except Exception as e:
            logger.error(f"Error in scale-in processing: {e}")
    
    async def _process_risk_adjustment(self):
        """Process LLM-driven dynamic risk adjustment"""
        if not self.risk_adjuster:
            return
        
        try:
            # Check if adjustment should run
            if not self.risk_adjuster.should_adjust():
                return
            
            logger.info("  🔄 Running dynamic risk adjustment (LLM)...")
            
            # Run adjustment (synchronous, but fast)
            new_config = self.risk_adjuster.adjust()
            
            if new_config:
                logger.info("  ✅ Risk parameters adjusted by LLM")
                
                # Reload risk config for the risk guard
                # The risk guard will pick up new values on next check
                
                # Log the adjustment
                if self.centralized_logger:
                    self.centralized_logger.log_risk(
                        risk_level="ADJUSTED",
                        equity=self.risk_guard.get_status().get("equity", 0),
                        max_position_pct=new_config.get("global", {}).get("max_equity_risk_pct_per_trade", 0),
                        current_exposure_pct=0,
                        daily_loss_pct=0,
                        drawdown_pct=0,
                        open_positions_count=0,
                        trades_today=0,
                        can_trade=True
                    )
            else:
                logger.debug("  ⏭️ Risk adjustment skipped (rate limit or error)")
                
        except Exception as e:
            logger.error(f"Error in risk adjustment: {e}")
    
    async def _self_heal_positions(self):
        """
        SELF-HEALING: Check all positions and fix issues automatically.
        
        Issues to fix:
        1. Missing SL/TP orders - add them if not present
        2. Wrong leverage - reduce to safe levels based on equity
        3. Duplicate orders - cancel and recreate to ensure clean state
        
        This runs periodically to ensure positions are always protected.
        
        IMPORTANT: This should ALIGN the system state, not create new positions.
        """
        try:
            logger.info("  🔧 SELF-HEAL: Checking positions for issues...")
            
            # CRITICAL FIX: First sync trade_state with exchange to remove stale entries
            # This prevents phantom positions from causing issues
            try:
                from trade_state import sync_all_with_exchange
                sync_result = sync_all_with_exchange()
                if sync_result.get("removed"):
                    stale_count = len(sync_result['removed'])
                    self._healing_metrics['stale_positions_cleaned'] += stale_count
                    logger.info(f"  🔧 SELF-HEAL: Cleared stale trade_state entries: {sync_result['removed']}")
                if sync_result.get("synced"):
                    logger.info(f"  🔧 SELF-HEAL: Synced positions: {sync_result['synced']}")
            except Exception as sync_err:
                logger.warning(f"  ⚠️ SELF-HEAL: trade_state sync failed: {sync_err}")
                self._healing_metrics['heal_errors'].append(str(sync_err))
            
            # Get current equity to determine safe leverage
            equity = self._get_api_equity()
            
            # Determine max leverage based on equity
            if equity < 100:
                MAX_LEVERAGE = 3
            elif equity < 500:
                MAX_LEVERAGE = 5
            else:
                MAX_LEVERAGE = 10
            
            # Get all open positions from exchange
            api_positions = self._get_api_positions()
            
            if not api_positions:
                logger.debug("  ⏭️ No open positions to heal")
                return
            
            logger.info(f"  🔧 SELF-HEAL: Checking {len(api_positions)} positions...")
            
            for symbol, position in api_positions.items():
                position_amt = float(position.get("positionAmt", 0))
                if position_amt == 0:
                    continue
                
                entry_price = float(position.get("entryPrice", 0))
                current_leverage = int(position.get("leverage", 0))
                
                # Determine position side
                side = "SELL" if position_amt < 0 else "BUY"
                quantity = abs(position_amt)
                
                # Issue 1: Check and fix leverage
                if current_leverage > MAX_LEVERAGE:
                    logger.warning(f"  ⚠️ SELF-HEAL: {symbol} has {current_leverage}x leverage (should be {MAX_LEVERAGE}x), reducing...")
                    try:
                        from api.aster_api import set_leverage
                        result = set_leverage(symbol, MAX_LEVERAGE)
                        if result and not result.get("error"):
                            logger.info(f"  ✅ SELF-HEAL: {symbol} leverage reduced to {MAX_LEVERAGE}x")
                            self._healing_metrics['leverage_adjusted'] += 1
                            self._healing_metrics['total_heals'] += 1
                        else:
                            logger.warning(f"  ⚠️ SELF-HEAL: Failed to reduce leverage for {symbol}: {result}")
                    except Exception as e:
                        logger.error(f"  ❌ SELF-HEAL: Error reducing leverage for {symbol}: {e}")
                        self._healing_metrics['heal_errors'].append(str(e))
                
                # Issue 2: Check and add missing SL/TP orders
                # CRITICAL FIX: Only add if MISSING - do NOT cancel existing orders
                # Canceling and re-creating on every loop causes order spam
                try:
                    from api.aster_api import get_open_orders
                    
                    # Get current open orders to check what's missing
                    open_orders = get_open_orders(symbol)
                    
                    # Check what SL/TP orders exist
                    has_sl = False
                    has_tp = False
                    
                    if open_orders and isinstance(open_orders, list):
                        for order in open_orders:
                            order_type = order.get("type", "")
                            if "STOP" in order_type and "TAKE" not in order_type:
                                has_sl = True
                            elif "TAKE" in order_type:
                                has_tp = True
                    
                    # Only add SL if completely MISSING (not just cancel/recreate)
                    if not has_sl:
                        logger.warning(f"  ⚠️ SELF-HEAL: {symbol} missing SL order, adding...")
                        try:
                            sl_result = await self._place_stop_loss(symbol, side, quantity, entry_price)
                            if sl_result and sl_result.get('orderId'):
                                logger.info(f"  ✅ SELF-HEAL: {symbol} SL order placed: {sl_result.get('orderId')}")
                                self._healing_metrics['sl_orders_added'] += 1
                                self._healing_metrics['total_heals'] += 1
                            else:
                                logger.error(f"  ❌ SELF-HEAL: {symbol} SL order FAILED: {sl_result}")
                        except Exception as sl_err:
                            logger.error(f"  ❌ SELF-HEAL: {symbol} SL order exception: {sl_err}")
                            self._healing_metrics['heal_errors'].append(str(sl_err))
                    else:
                        logger.debug(f"  ✅ SELF-HEAL: {symbol} SL order exists, skipping")
                    
                    # Only add TP if completely MISSING
                    if not has_tp:
                        logger.warning(f"  ⚠️ SELF-HEAL: {symbol} missing TP order, adding...")
                        try:
                            tp_result = await self._place_take_profit_orders(symbol, side, quantity, entry_price)
                            logger.info(f"  ✅ SELF-HEAL: {symbol} TP orders placed")
                            self._healing_metrics['tp_orders_added'] += 1
                            self._healing_metrics['total_heals'] += 1
                        except Exception as tp_err:
                            logger.error(f"  ❌ SELF-HEAL: {symbol} TP order exception: {tp_err}")
                            self._healing_metrics['heal_errors'].append(str(tp_err))
                    else:
                        logger.debug(f"  ✅ SELF-HEAL: {symbol} TP orders exist, skipping")
                        
                except Exception as e:
                    logger.error(f"  ❌ SELF-HEAL: Error checking/adding SL/TP for {symbol}: {e}")
                    self._healing_metrics['heal_errors'].append(str(e))
            
            # Update last heal timestamp and log metrics
            import time
            self._healing_metrics['last_heal_timestamp'] = int(time.time() * 1000)
            logger.info(
                f"  ✅ SELF-HEAL: Position check complete. "
                f"Metrics: total_heals={self._healing_metrics['total_heals']}, "
                f"sl_added={self._healing_metrics['sl_orders_added']}, "
                f"tp_added={self._healing_metrics['tp_orders_added']}, "
                f"leverage_adj={self._healing_metrics['leverage_adjusted']}, "
                f"stale_cleaned={self._healing_metrics['stale_positions_cleaned']}"
            )
            
            # Refresh positions data after healing to update the dashboard
            try:
                api_positions = self._get_api_positions()
                if api_positions:
                    self.risk_guard.sync_with_exchange(api_positions)
                    logger.info("  🔄 SELF-HEAL: Positions data refreshed")
            except Exception as refresh_err:
                logger.warning(f"  ⚠️ SELF-HEAL: Could not refresh positions: {refresh_err}")
            
        except Exception as e:
            logger.error(f"  ❌ SELF-HEAL: Error in self-healing: {e}")
    
    def get_status(self) -> Dict:
        """Obtiene estado del sistema"""
        return {
            "running": self.state.running,
            "uptime_seconds": (int(time.time() * 1000) - self.state.start_time) / 1000 if self.state.start_time else 0,
            "loop_count": self.state.loop_count,
            "trades_executed": self.state.trades_executed,
            "last_feature_update": self.state.last_feature_update,
            "components": {
                "websocket": self.ws_manager.connected if self.ws_manager else False,
                "ml_model": self.signal_generator.get_model_info() if self.signal_generator else {},
                "llm": self.llm_guardian.get_usage_stats() if self.llm_guardian else {},
                "risk": self.risk_guard.get_status() if self.risk_guard else {},
            },
            "errors": self.state.errors[-5:]  # Últimos 5 errores
        }


# =======================
# ENTRY POINT
# =======================

async def main():
    """Punto de entrada principal"""
    print("=" * 60)
    print("  ASTER TRADING SYSTEM V2")
    print("  ML-driven + LLM Guardian (Limited)")
    print("=" * 60)
    
    # Crear sistema
    config = TradingConfig(
        symbols=["ASTERUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "HYPEUSDT"],
        main_loop_seconds=60,
        use_testnet=False
    )
    
    system = TradingSystemV2(config)
    
    try:
        # Inicializar
        await system.initialize()
        
        # Mostrar status
        status = system.get_status()
        print(f"\n📊 Estado inicial:")
        print(f"   ML Model: {status['components']['ml_model'].get('model_type', 'N/A')}")
        print(f"   LLM Provider: {status['components']['llm'].get('provider', 'N/A')}")
        print(f"   Risk Level: {status['components']['risk'].get('risk_level', 'N/A')}")
        
        # Iniciar el loop principal
        await system.start()
        
    except KeyboardInterrupt:
        print("\n🛑 Interrumpido por usuario")
    except Exception as e:
        print(f"\n❌ Error: {e}")


if __name__ == "__main__":
    asyncio.run(main())
